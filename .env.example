# Public Supabase project URL for the target environment.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anon key for browser-safe reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role key. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Basic-auth password for protected admin/internal routes.
ADMIN_SECRET=

# Stripe testmode only. Use sk_test_... locally/staging.
# Do not use sk_live_... until live payments are explicitly approved.
STRIPE_SECRET_KEY=

# Optional Stripe test price for the founding member yearly plan.
STRIPE_PRICE_FOUNDING_MEMBER_YEARLY=

# Optional Stripe webhook secret for local/staging webhook tests.
STRIPE_WEBHOOK_SECRET=
